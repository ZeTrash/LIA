{
  "$id": "https://lia.local/schemas/memory-context.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MemoryContext",
  "type": "object",
  "required": [
    "traits",
    "session_goals",
    "memories",
    "indicators",
    "governance_metadata"
  ],
  "properties": {
    "traits": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "$ref": "#/$defs/Trait"
      }
    },
    "session_goals": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "$ref": "#/$defs/SessionGoal"
      }
    },
    "memories": {
      "type": "array",
      "maxItems": 40,
      "items": {
        "$ref": "#/$defs/Souvenir"
      }
    },
    "indicators": {
      "$ref": "#/$defs/IndicatorBundle"
    },
    "governance_metadata": {
      "type": "object",
      "required": ["context_version", "build_time_ms"],
      "properties": {
        "context_version": {
          "type": "string",
          "pattern": "^[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}-[0-9]{2}$"
        },
        "build_time_ms": {
          "type": "integer",
          "maximum": 200
        },
        "trace_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "Trait": {
      "type": "object",
      "required": [
        "trait_id",
        "type",
        "label",
        "value",
        "version",
        "weight",
        "confidence",
        "status"
      ],
      "properties": {
        "trait_id": {
          "type": "string"
        },
        "type": {
          "enum": ["persona", "skill", "style", "constraint"]
        },
        "label": {
          "type": "string"
        },
        "value": {
          "type": "string"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "origin": {
          "type": "string"
        },
        "status": {
          "enum": ["active", "staged", "deprecated"]
        },
        "last_update": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "Souvenir": {
      "type": "object",
      "required": [
        "memory_id",
        "category",
        "content",
        "importance_score",
        "recency_score",
        "emotion_score",
        "frequency",
        "ttl"
      ],
      "properties": {
        "memory_id": {
          "type": "string"
        },
        "category": {
          "enum": ["fact", "preference", "alert"]
        },
        "content": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "maxItems": 12
        },
        "importance_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "recency_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "emotion_score": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "frequency": {
          "type": "integer",
          "minimum": 0
        },
        "ttl": {
          "type": "string",
          "format": "date-time"
        },
        "source": {
          "type": "string"
        },
        "link_refs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "id"],
            "properties": {
              "type": {
                "enum": ["trait", "experience", "interaction"]
              },
              "id": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "hash": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "SessionGoal": {
      "type": "object",
      "required": [
        "goal_id",
        "session_id",
        "priority",
        "description",
        "expires_at"
      ],
      "properties": {
        "goal_id": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        },
        "priority": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "description": {
          "type": "string"
        },
        "blocking_conditions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "maxItems": 8
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "IndicatorBundle": {
      "type": "object",
      "properties": {
        "coherence_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "drift_score": {
          "type": "number",
          "minimum": 0
        },
        "drift_alert": {
          "type": "boolean"
        },
        "latency_context_ms": {
          "type": "integer",
          "minimum": 0,
          "maximum": 200
        },
        "coverage_traits_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      },
      "additionalProperties": false
    }
  }
}




