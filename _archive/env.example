# Configuration environnement - Template
# Copier ce fichier vers .env et remplir avec vos valeurs réelles
# Ne jamais commiter .env dans le dépôt Git

# Service mémoire
MEMORY_SERVICE_HOST=127.0.0.1
MEMORY_SERVICE_PORT=8000
MEMORY_SERVICE_DEBUG=false

# Base de données
DATABASE_URL=sqlite:///./memory_service/data/memory.db
# Pour PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/lia_db

# Configuration TTL (jours)
TTL_FACT=45
TTL_PREFERENCE=180
TTL_ALERT=15

# Seuils de gouvernance
GOVERNANCE_THRESHOLD_WARN=0.35
GOVERNANCE_THRESHOLD_BLOCK=0.55

# Limites
MAX_MEMORIES=12
CONTEXT_PAYLOAD_MAX_KB=10
CONTEXT_LATENCY_MAX_MS=200

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/memory_service.log



